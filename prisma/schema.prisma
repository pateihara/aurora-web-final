generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  DRIVER
  ADMIN
}

enum VehicleType {
  EV
  PHEV
}

enum ChargerStatus {
  AVAILABLE
  OCCUPIED
  OFFLINE
  MAINTENANCE
}

enum ConnectorType {
  CCS2
  CHADEMO
  TYPE2
  AC
  GBT
}

enum ChargingSessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model User {
  id       String   @id @default(cuid())
  name     String
  email    String   @unique
  password String
  role     UserRole @default(DRIVER)

  sparks       Int @default(0)
  reviewsCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicles         Vehicle[]
  reviews          Review[]
  favorites        Favorite[]
  chargingHistory  ChargingHistory[]
  chargingSessions ChargingSession[]
}

model Vehicle {
  id                    String        @id @default(cuid())
  nickname              String        @default("Meu veículo")
  brand                 String        @default("Outro")
  model                 String
  year                  String        @default("2023")
  plate                 String        @default("ABC1D23")
  type                  VehicleType   @default(EV)
  connector             ConnectorType
  batteryCapacityKwh    Float         @default(75)
  rangeKm               Int
  maxPowerKw            Int
  currentBatteryPercent Int           @default(80)
  isActive              Boolean       @default(false)

  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Station {
  id        String   @id @default(cuid())
  name      String
  address   String
  city      String
  state     String
  latitude  Float
  longitude Float
  isOpen24h Boolean  @default(true)
  amenities String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chargers         Charger[]
  reviews          Review[]
  favorites        Favorite[]
  chargingHistory  ChargingHistory[]
  chargingSessions ChargingSession[]
}

model Charger {
  id        String        @id @default(cuid())
  label     String
  connector ConnectorType
  powerKw   Int
  status    ChargerStatus @default(AVAILABLE)
  stationId String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  station          Station           @relation(fields: [stationId], references: [id], onDelete: Cascade)
  chargingSessions ChargingSession[]

  @@index([stationId])
}

model Review {
  id                String  @id @default(cuid())
  rating            Int
  feeling           String?
  comment           String?
  availabilityScore Int
  qualityScore      Int
  amenitiesScore    Int
  signageScore      Int
  sparksEarned      Int     @default(30)

  userId    String
  stationId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stationId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  stationId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([userId, stationId])
  @@index([userId])
  @@index([stationId])
}

model ChargingHistory {
  id        String   @id @default(cuid())
  userId    String
  stationId String
  kwh       Float
  minutes   Int
  cost      Float
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stationId])
}

model ChargingSession {
  id        String                @id @default(cuid())
  userId    String
  stationId String
  chargerId String
  status    ChargingSessionStatus @default(ACTIVE)

  selectedMinutes Int
  pricePerMinute  Float
  estimatedCost   Float

  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)
  charger Charger @relation(fields: [chargerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stationId])
  @@index([chargerId])
  @@index([status])
}

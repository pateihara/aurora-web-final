generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  DRIVER
  ADMIN
}

enum ChargerStatus {
  AVAILABLE
  OCCUPIED
  OFFLINE
  MAINTENANCE
}

enum ConnectorType {
  CCS2
  CHADEMO
  TYPE2
  AC
  GBT
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(DRIVER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicles        Vehicle[]
  reviews         Review[]
  favorites       Favorite[]
  chargingHistory ChargingHistory[]
}

model Vehicle {
  id         String        @id @default(cuid())
  model      String
  connector  ConnectorType
  rangeKm    Int
  maxPowerKw Int
  userId     String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Station {
  id        String   @id @default(cuid())
  name      String
  address   String
  city      String
  state     String
  latitude  Float
  longitude Float
  isOpen24h Boolean  @default(true)
  amenities String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chargers        Charger[]
  reviews         Review[]
  favorites       Favorite[]
  chargingHistory ChargingHistory[]
}

model Charger {
  id        String        @id @default(cuid())
  label     String
  connector ConnectorType
  powerKw   Int
  status    ChargerStatus @default(AVAILABLE)
  stationId String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)
}

model Review {
  id                String   @id @default(cuid())
  rating            Int
  comment           String?
  availabilityScore Int
  qualityScore      Int
  amenitiesScore    Int
  signageScore      Int
  userId            String
  stationId         String
  createdAt         DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  stationId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([userId, stationId])
}

model ChargingHistory {
  id        String   @id @default(cuid())
  userId    String
  stationId String
  kwh       Float
  minutes   Int
  cost      Float
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)
}